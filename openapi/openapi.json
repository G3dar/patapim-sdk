{
  "openapi": "3.0.3",
  "info": {
    "title": "PATAPIM Local API",
    "version": "1.0",
    "description": "Local HTTP+WS API served by the PATAPIM desktop app on http://127.0.0.1:31415. Authenticate with a scoped token created in PATAPIM Preferences → Developer → Local API, passed via the `x-patapim-token` header (or `Authorization: Bearer`). v1 is additive-only: routes, parameters and response fields are never removed or renamed.\n\nApp version: 1.5.10"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:31415"
    }
  ],
  "components": {
    "securitySchemes": {
      "patapimToken": {
        "type": "apiKey",
        "in": "header",
        "name": "x-patapim-token"
      }
    }
  },
  "x-scopes": {
    "terminals:read": "List terminals and read their buffers/state",
    "terminals:write": "Create terminals, send input, resize, close",
    "tasks": "Read and manage project tasks and scheduled commands",
    "notifications": "Send notifications through the user's configured channels",
    "browser": "Drive the embedded browser (navigate, click, screenshot)",
    "files:read": "Read files in project directories",
    "files:write": "Write files in project directories",
    "events": "Subscribe to the WebSocket event stream"
  },
  "paths": {
    "/api/v1/terminals": {
      "get": {
        "summary": "List all terminals with live state (processing, attention, plan mode)",
        "operationId": "getTerminals",
        "security": [
          {
            "patapimToken": []
          }
        ],
        "x-required-scope": "terminals:read",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success"
          },
          "401": {
            "description": "Invalid or missing token, or Local API disabled (code: INVALID_TOKEN | API_DISABLED)"
          },
          "403": {
            "description": "Token lacks the required scope \"terminals:read\" (code: MISSING_SCOPE)"
          }
        }
      },
      "post": {
        "summary": "Create a terminal. Subject to the plan's terminal limit.",
        "operationId": "postTerminals",
        "security": [
          {
            "patapimToken": []
          }
        ],
        "x-required-scope": "terminals:write",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success"
          },
          "401": {
            "description": "Invalid or missing token, or Local API disabled (code: INVALID_TOKEN | API_DISABLED)"
          },
          "403": {
            "description": "Token lacks the required scope \"terminals:write\" (code: MISSING_SCOPE)"
          }
        },
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cwd": {
                    "type": "string",
                    "description": "string?"
                  },
                  "projectPath": {
                    "type": "string",
                    "description": "string?"
                  },
                  "shell": {
                    "type": "string",
                    "description": "string?"
                  },
                  "cols": {
                    "type": "number",
                    "description": "number?"
                  },
                  "rows": {
                    "type": "number",
                    "description": "number?"
                  }
                }
              }
            }
          }
        }
      }
    },
